{
  "build": {
    "core": "esp32",
    "cpu": "esp32s3",
    "extra_flags": [
      "-DARDUINO=10805",
      "-DESP32S3"
    ],
    "flash_mode": "qio",
    "f_cpu": "240000000L",
    "f_flash": "80000000L",
    "board_flash_erase": "",    
    "ldscript": "esp32s3_out.ld"
  },
  "frameworks": [
    "arduino"
  ],
  "platform": "espressif32",
  "name": "Custom ESP32-S3 Board",
  "upload": {
    "protocol": "esptool",
    "speed": 921600
  },
  "url": "http://example.com/your-board",
  "vendor": "custom"
}